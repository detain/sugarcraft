#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * `candyfreeze` — render code or terminal output to an SVG screenshot.
 *
 * Usage:
 *   echo "hello" | candyfreeze --theme dracula > out.svg
 *   candyfreeze input.txt --theme tokyo-night --no-window --line-numbers
 *
 * Reads from stdin when no path is supplied; writes the SVG to
 * stdout (or `--output <path>`).
 */

$root = dirname(__DIR__, 2);
foreach ([__DIR__ . '/../vendor/autoload.php', $root . '/vendor/autoload.php'] as $auto) {
    if (file_exists($auto)) {
        require $auto;
        break;
    }
}

use SugarCraft\Freeze\CodeHighlighter;
use SugarCraft\Freeze\Lang;
use SugarCraft\Freeze\LanguageDetector;
use SugarCraft\Freeze\PngRenderer;
use SugarCraft\Freeze\SvgRenderer;
use SugarCraft\Freeze\Theme;

/**
 * Resolve a filesystem path and require it to live inside the current working
 * directory, defeating `../` traversal and absolute-path escapes before we
 * read or write attacker-influenced locations. Returns the resolved absolute
 * path, or null when it escapes the CWD (the caller rejects with exit 2).
 *
 * `$unsafe` (the `--unsafe-paths` opt-out) bypasses confinement entirely.
 *
 * Paths that do not yet exist (e.g. an `--output` target, or a new file in the
 * CWD) are confined by their nearest existing ancestor directory, so creating
 * a file inside the CWD stays allowed while writing outside it does not.
 */
function candyfreeze_confine_path(string $path, bool $unsafe): ?string
{
    if ($unsafe) {
        return $path;
    }
    $cwd = realpath(getcwd() ?: '.');
    if ($cwd === false) {
        return null;
    }
    $cwd = rtrim($cwd, DIRECTORY_SEPARATOR);

    $absolute = preg_match('#^([/\\\\]|[A-Za-z]:)#', $path) === 1
        ? $path
        : $cwd . DIRECTORY_SEPARATOR . $path;

    // Walk up to the nearest existing ancestor so a not-yet-created target is
    // still confined by the directory it would be written into.
    $ancestor = $absolute;
    while (($real = realpath($ancestor)) === false) {
        $parent = dirname($ancestor);
        if ($parent === $ancestor) {
            return null; // ran off the filesystem root without resolving
        }
        $ancestor = $parent;
    }
    $resolved = $real . substr($absolute, strlen($ancestor));

    $prefix = $cwd . DIRECTORY_SEPARATOR;
    if ($resolved !== $cwd && !str_starts_with($resolved, $prefix)) {
        return null;
    }
    return $resolved;
}

$argv = $_SERVER['argv'] ?? $argv ?? [];
array_shift($argv);

$themeName      = 'dark';
$padding        = 24;
$window         = true;
$shadow         = true;
$border         = true;
$lineNumbers    = false;
$borderRadius   = 8;
$windowStyle    = null;
$ligatures      = false;
$fontPath       = null;
$highlight      = null;
$output         = null;
$inputPath      = null;
$format         = 'svg';
$language       = null;
$unsafePaths    = false;

while (($arg = array_shift($argv)) !== null) {
    switch ($arg) {
        case '--theme':         $themeName    = (string) array_shift($argv); break;
        case '--padding':       $padding      = (int) array_shift($argv); break;
        case '--no-window':     $window       = false; break;
        case '--no-shadow':     $shadow       = false; break;
        case '--no-border':     $border       = false; break;
        case '--line-numbers':  $lineNumbers  = true;  break;
        case '--border-radius': $borderRadius = (int) array_shift($argv); break;
        case '--window-style':
            $styleRaw = (string) array_shift($argv);
            $valid = ['macos', 'windows-terminal', 'iterm', 'hyper', 'none'];
            if (!in_array($styleRaw, $valid, true)) {
                fwrite(STDERR, Lang::t('cli.unknown_window_style', ['style' => $styleRaw]) . "\n");
                exit(2);
            }
            $windowStyle = $styleRaw;
            break;
        case '--ligatures':     $ligatures    = true; break;
        case '--unsafe-paths':  $unsafePaths  = true; break;
        case '--font':
            // Existence, confinement and font-signature checks are deferred
            // until after parsing so --unsafe-paths (order-independent) applies.
            $fontPath = (string) array_shift($argv);
            break;
        case '--highlight':
            $hlFormat = (string) array_shift($argv);
            if (!preg_match('/^(\d+):(\d+)(?::([^:]+))?$/', $hlFormat, $m)) {
                fwrite(STDERR, Lang::t('cli.bad_highlight', ['format' => $hlFormat]) . "\n");
                exit(2);
            }
            $start = (int) $m[1];
            $end   = (int) $m[2];
            $color = $m[3] ?? '#fffbe6';
            $highlight = [$start, $end, $color];
            break;
        case '-o':
        case '--output':        $output       = (string) array_shift($argv); break;
        case '--format':
            $format = (string) array_shift($argv);
            if (!in_array($format, ['svg', 'png'], true)) {
                fwrite(STDERR, Lang::t('cli.unknown_format', ['format' => $format]) . "\n");
                exit(2);
            }
            break;
        case '-t':
        case '--type':
            $language = (string) array_shift($argv);
            break;
        case '-h':
        case '--help':
            fwrite(STDOUT, Lang::t('cli.usage') . "\n");
            exit(0);
        default:
            if ($inputPath === null && !str_starts_with($arg, '-')) {
                $inputPath = $arg;
            } else {
                fwrite(STDERR, Lang::t('cli.unknown_flag', ['flag' => $arg]) . "\n");
                exit(2);
            }
    }
}

$theme = match (strtolower(str_replace('_', '-', $themeName))) {
    'dark'        => Theme::dark(),
    'light'       => Theme::light(),
    'dracula'     => Theme::dracula(),
    'tokyo-night' => Theme::tokyoNight(),
    'nord'        => Theme::nord(),
    default       => null,
};
if ($theme === null) {
    fwrite(STDERR, Lang::t('cli.unknown_theme', ['name' => $themeName]) . "\n");
    exit(2);
}

// Confine every attacker-influenced filesystem path to the CWD (defeats `../`
// traversal, absolute-path escapes and symlink hops) unless the operator
// explicitly opts out with --unsafe-paths.
if ($inputPath !== null) {
    $confined = candyfreeze_confine_path($inputPath, $unsafePaths);
    if ($confined === null) {
        fwrite(STDERR, Lang::t('cli.path_outside_cwd', ['path' => $inputPath]) . "\n");
        exit(2);
    }
    $inputPath = $confined;
}
if ($output !== null) {
    $confined = candyfreeze_confine_path($output, $unsafePaths);
    if ($confined === null) {
        fwrite(STDERR, Lang::t('cli.path_outside_cwd', ['path' => $output]) . "\n");
        exit(2);
    }
    $output = $confined;
}
if ($fontPath !== null) {
    $confined = candyfreeze_confine_path($fontPath, $unsafePaths);
    if ($confined === null) {
        fwrite(STDERR, Lang::t('cli.path_outside_cwd', ['path' => $fontPath]) . "\n");
        exit(2);
    }
    $fontPath = $confined;
    if (!is_file($fontPath)) {
        fwrite(STDERR, Lang::t('cli.font_not_found', ['path' => $fontPath]) . "\n");
        exit(2);
    }
    // Reject any blob without a real font signature before base64-embedding it
    // into the SVG — a hostile file could otherwise smuggle in markup/script.
    $fontHead = @file_get_contents($fontPath, false, null, 0, 4);
    if ($fontHead === false || SvgRenderer::sniffFontMime($fontHead) === null) {
        fwrite(STDERR, Lang::t('cli.font_invalid', ['path' => $fontPath]) . "\n");
        exit(2);
    }
}

$text = $inputPath !== null
    ? @file_get_contents($inputPath)
    : stream_get_contents(STDIN);
if ($text === false || $text === null) {
    fwrite(STDERR, Lang::t('cli.read_failed') . "\n");
    exit(1);
}

// Detect the language, then apply plaintext syntax highlighting — but only for
// raw source. If the input already carries its own ANSI SGR (e.g. captured
// terminal output) we pass it through untouched so pre-styled colours win and
// the render stays byte-identical. Unrecognised / plain-text languages tokenise
// to a single Plain span, so CodeHighlighter::highlight() returns the input
// unchanged; the `!== 'text'` guard just skips the needless tokenise pass.
$detectedLang = LanguageDetector::detect($text);
if ($language === null) {
    $language = $detectedLang;
}
if (strpos($text, "\x1b") === false && $language !== 'text' && $language !== '') {
    $text = CodeHighlighter::forTheme($theme)->highlight($text, $language);
}

if ($format === 'png') {
    if (!extension_loaded('gd')) {
        fwrite(STDERR, Lang::t('cli.gd_required') . "\n");
        exit(2);
    }
    $renderer = new PngRenderer(
        theme:        $theme,
        padding:      $padding,
        window:       $window,
        shadow:       $shadow,
        border:       $border,
        lineNumbers:  $lineNumbers,
        borderRadius: $borderRadius,
    );
} else {
    $renderer = new SvgRenderer(
        theme:        $theme,
        padding:      $padding,
        window:       $window,
        shadow:       $shadow,
        border:       $border,
        lineNumbers:  $lineNumbers,
        borderRadius: $borderRadius,
    );
    if ($ligatures) {
        $renderer = $renderer->withLigatures(true);
    }
    if ($fontPath !== null) {
        try {
            $renderer = $renderer->withFont($fontPath);
        } catch (\InvalidArgumentException $e) {
            fwrite(STDERR, Lang::t('cli.font_not_found', ['path' => $fontPath]) . "\n");
            exit(2);
        }
    }
    if ($highlight !== null) {
        [$start, $end, $color] = $highlight;
        $renderer = $renderer->withHighlight($start, $end, $color);
    }
}
if ($windowStyle !== null) {
    $renderer = $renderer->withWindowStyle($windowStyle);
}

$result = $renderer->render($text);

if ($output !== null) {
    if (@file_put_contents($output, $result) === false) {
        fwrite(STDERR, Lang::t('cli.write_failed', ['path' => $output]) . "\n");
        exit(1);
    }
} else {
    echo $result;
}
