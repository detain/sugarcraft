#!/usr/bin/env php
<?php

declare(strict_types=1);

(static function () {
    foreach (['vendor/autoload.php', __DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $candidate) {
        $path = str_starts_with($candidate, '/') ? $candidate : __DIR__ . '/../' . $candidate;
        if (is_file($path)) {
            require $path;
            return;
        }
    }
    fwrite(STDERR, "sugar-stash: cannot find composer autoload.php\n");
    exit(1);
})();

use SugarCraft\Core\Program;
use SugarCraft\Core\ProgramOptions;
use SugarCraft\Stash\App;
use SugarCraft\Stash\Git;
use SugarCraft\Stash\Lang;

$cwd = getcwd();
// Probe via git itself rather than is_dir("$cwd/.git") so we launch inside a
// LINKED worktree too, where `.git` is a file (gitdir pointer), not a dir.
if ($cwd === false || !Git::isRepository($cwd)) {
    fwrite(STDERR, Lang::t('cli.not_a_repo', ['cwd' => (string) $cwd]) . "\n");
    exit(1);
}
(new Program(App::start(new Git($cwd)), new ProgramOptions(useAltScreen: true)))->run();
