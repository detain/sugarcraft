{
    "name": "candycore/candy-sprinkles",
    "description": "PHP port of charmbracelet/lipgloss — declarative terminal styling and layout.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui", "terminal", "cli",
        "lipgloss", "ansi", "styling", "layout",
        "borders", "tables", "tree", "list",
        "candycore"
    ],
    "homepage": "https://github.com/detain/CandyCore",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/detain/CandyCore/issues",
        "source": "https://github.com/detain/CandyCore",
        "docs":   "https://github.com/detain/CandyCore/blob/master/CONVERSION.md"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Sprinkles\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Sprinkles\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
